{
  "info": {
    "name": "AutoRia Clone",
    "description": "Full flow testing for AutoRia Clone — car marketplace platform.\n\nRun requests in order (1 → 40). Tokens and IDs are captured automatically via test scripts.\n\n**Credentials:**\n- Admin: admin@autoria.ua / Admin123!\n- Seller: seller@test.ua / Seller123!\n- Buyer: buyer@test.ua / Buyer123!\n- Manager: manager@test.ua / Manager123!\n\n**Base URL:** http://localhost:8000",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "admin_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "seller_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "seller_refresh",
      "value": "",
      "type": "string"
    },
    {
      "key": "buyer_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "manager_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "seller_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "buyer_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "manager_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "listing_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "listing2_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "profanity_listing_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "brand_request_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "brand_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "run_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Anonymous Access",
      "item": [
        {
          "name": "1. List active listings (anonymous)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/listings/",
            "description": "Anyone can browse listings without authentication."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response has results array', () => pm.expect(pm.response.json()).to.have.property('results'));"
                ]
              }
            }
          ]
        },
        {
          "name": "2. List all car brands (anonymous)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/cars/brands",
            "description": "Anyone can see all car brands. Expects 15 seeded brands."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const brands = pm.response.json();",
                  "pm.test('Brands seeded', () => pm.expect(brands.length).to.be.above(0));",
                  "if (brands.length > 0) pm.collectionVariables.set('brand_id', brands[0].id);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "2. Admin Setup",
      "item": [
        {
          "name": "3. Admin login",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"admin@autoria.ua\", \"password\": \"Admin123!\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const data = pm.response.json();",
                  "pm.collectionVariables.set('admin_token', data.tokens.access);",
                  "pm.test('Role is admin', () => pm.expect(data.user.role).to.equal('admin'));"
                ]
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Generate a unique suffix for this run so test users are always fresh",
                  "const rid = Date.now().toString().slice(-6);",
                  "pm.collectionVariables.set('run_id', rid);",
                  "pm.collectionVariables.set('manager_email', 'manager_' + rid + '@test.ua');",
                  "pm.collectionVariables.set('seller_email',  'seller_'  + rid + '@test.ua');",
                  "pm.collectionVariables.set('buyer_email',   'buyer_'   + rid + '@test.ua');"
                ]
              }
            }
          ]
        },
        {
          "name": "4. List roles",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/roles/",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "description": "View all 4 roles: buyer, seller, manager, admin."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('4 roles exist', () => pm.expect(pm.response.json().results.length).to.equal(4));"
                ]
              }
            }
          ]
        },
        {
          "name": "5. List permissions",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/roles/permissions",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "description": "View all 16 system permissions."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('16 permissions exist', () => pm.expect(pm.response.json().results.length).to.equal(16));"
                ]
              }
            }
          ]
        },
        {
          "name": "6. Create manager (admin only)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/users/create-manager",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"manager_{{run_id}}@test.ua\", \"password\": \"Manager123!\", \"first_name\": \"Test\", \"last_name\": \"Manager\"}"
            },
            "description": "Only admin can create a manager account."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const data = pm.response.json();",
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('manager_id', data.id);",
                  "  pm.test('Role is manager', () => pm.expect(data.role.name).to.equal('manager'));",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "3. Registration",
      "item": [
        {
          "name": "7. Register seller",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"seller_{{run_id}}@test.ua\", \"password\": \"Seller123!\", \"first_name\": \"Ivan\", \"last_name\": \"Seller\", \"phone\": \"+380501234567\", \"role_name\": \"seller\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const data = pm.response.json();",
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('seller_id', data.user.id);",
                  "  pm.collectionVariables.set('seller_token', data.tokens.access);",
                  "  pm.collectionVariables.set('seller_refresh', data.tokens.refresh);",
                  "  pm.test('Has access token', () => pm.expect(data.tokens.access).to.be.a('string'));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "8. Register buyer",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"buyer_{{run_id}}@test.ua\", \"password\": \"Buyer123!\", \"first_name\": \"Petro\", \"last_name\": \"Buyer\", \"phone\": \"+380507654321\", \"role_name\": \"buyer\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const data = pm.response.json();",
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('buyer_id', data.user.id);",
                  "  pm.collectionVariables.set('buyer_token', data.tokens.access);",
                  "} else {",
                  "  pm.sendRequest({",
                  "    url: pm.collectionVariables.get('base_url') + '/api/auth/login',",
                  "    method: 'POST',",
                  "    header: [{'key':'Content-Type','value':'application/json'}],",
                  "    body: {mode:'raw', raw: JSON.stringify({email:pm.collectionVariables.get('buyer_email'), password:'Buyer123!'})}",
                  "  }, function(err, res) {",
                  "    if (!err && res.code === 200) {",
                  "      const d = res.json();",
                  "      pm.collectionVariables.set('buyer_id', d.user.id);",
                  "      pm.collectionVariables.set('buyer_token', d.tokens.access);",
                  "    }",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "4. Cars & Brand Requests",
      "item": [
        {
          "name": "9. Seller login",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"seller_{{run_id}}@test.ua\", \"password\": \"Seller123!\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const data = pm.response.json();",
                  "pm.collectionVariables.set('seller_id', data.user.id);",
                  "pm.collectionVariables.set('seller_token', data.tokens.access);",
                  "pm.collectionVariables.set('seller_refresh', data.tokens.refresh);"
                ]
              }
            }
          ]
        },
        {
          "name": "10. Get models for BMW (brand_id=1)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/cars/brands/{{brand_id}}/models",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{seller_token}}"
              }
            ],
            "description": "Browse models for a specific brand."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "11. Request new brand (seller)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/cars/brand-requests",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{seller_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"brand_name\": \"Lamborghini\", \"model_name\": \"Urus\", \"comment\": \"Popular luxury SUV, please add to catalog\"}"
            },
            "description": "Seller requests a brand/model not yet in the catalog."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const data = pm.response.json();",
                  "pm.collectionVariables.set('brand_request_id', data.id);",
                  "pm.test('Status is pending', () => pm.expect(data.status).to.equal('pending'));"
                ]
              }
            }
          ]
        },
        {
          "name": "12. Admin: list brand requests",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/cars/brand-requests",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "description": "Admin reviews pending brand requests."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "13. Admin: approve brand request",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/api/cars/brand-requests/{{brand_request_id}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"status\": \"approved\"}"
            },
            "description": "Admin approves the brand request — Lamborghini/Urus is added to the catalog automatically."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Status is approved', () => pm.expect(pm.response.json().status).to.equal('approved'));"
                ]
              }
            }
          ]
        },
        {
          "name": "14. Verify Lamborghini added to brands",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/cars/brands",
            "description": "After approval, Lamborghini should appear in the brands list (now 16)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const brands = pm.response.json();",
                  "pm.test('Lamborghini added, now 16 brands', () => pm.expect(brands.length).to.equal(16));",
                  "const lam = brands.find(b => b.name === 'Lamborghini');",
                  "pm.test('Lamborghini exists', () => pm.expect(lam).to.not.be.undefined);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "5. Listings — Basic Account",
      "item": [
        {
          "name": "15. Create listing (seller Basic, clean text)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/listings/",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{seller_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"car_brand\": 1, \"car_model\": 1, \"year\": 2022, \"description\": \"BMW 3 Series 2022, excellent condition, full service history, leather interior\", \"original_price\": 35000, \"original_currency\": \"USD\", \"region\": 9, \"city\": \"Kyiv\", \"mileage\": 25000, \"engine_type\": \"gasoline\"}"
            },
            "description": "Clean description → status becomes 'active' immediately."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const data = pm.response.json();",
                  "pm.collectionVariables.set('listing_id', data.id);",
                  "pm.test('Listing is active', () => pm.expect(data.status).to.equal('active'));",
                  "pm.test('Price USD set', () => pm.expect(data.price_usd).to.not.be.null);",
                  "pm.test('Price UAH set', () => pm.expect(data.price_uah).to.not.be.null);",
                  "pm.test('Exchange rate recorded', () => pm.expect(data.rate_usd_uah).to.not.be.null);"
                ]
              }
            }
          ]
        },
        {
          "name": "16. View listing detail (anonymous) — records a view",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/listings/{{listing_id}}",
            "description": "Each GET on a listing detail records a view for statistics."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const data = pm.response.json();",
                  "pm.test('Prices in all currencies', () => {",
                  "  pm.expect(data.price_usd).to.not.be.null;",
                  "  pm.expect(data.price_eur).to.not.be.null;",
                  "  pm.expect(data.price_uah).to.not.be.null;",
                  "});",
                  "pm.test('Original currency shown', () => pm.expect(data.original_currency).to.equal('USD'));",
                  "pm.test('Exchange rate date recorded', () => pm.expect(data.rate_date).to.not.be.null);"
                ]
              }
            }
          ]
        },
        {
          "name": "17. Check currency rates",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/currency/rates",
            "description": "PrivatBank rates fetched on startup, updated daily via Celery."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const data = pm.response.json();",
                  "pm.test('USD rate exists', () => pm.expect(data.some(r => r.ccy === 'USD')).to.be.true);",
                  "pm.test('EUR rate exists', () => pm.expect(data.some(r => r.ccy === 'EUR')).to.be.true);"
                ]
              }
            }
          ]
        },
        {
          "name": "18. Basic seller tries to create 2nd listing → 403",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/listings/",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{seller_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"car_brand\": 2, \"car_model\": 7, \"year\": 2020, \"description\": \"Mercedes C-Class for sale\", \"original_price\": 28000, \"original_currency\": \"EUR\", \"region\": 9, \"city\": \"Kyiv\", \"mileage\": 40000, \"engine_type\": \"diesel\"}"
            },
            "description": "Basic account limit: only 1 listing allowed. Must return 403."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403 — Basic limit enforced', () => pm.response.to.have.status(403));",
                  "pm.test('Error message about premium', () => pm.expect(pm.response.json().detail).to.include('Basic account'));"
                ]
              }
            }
          ]
        }
      ]
    },
