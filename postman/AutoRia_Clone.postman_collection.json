                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "7. Profanity Filter Flow",
      "item": [
        {
          "name": "21. Create listing WITH profanity → needs_edit",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/listings/",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{seller_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"car_brand\": 4, \"car_model\": 17, \"year\": 2019, \"description\": \"Toyota Camry хуйня повна продаю терміново\", \"original_price\": 20000, \"original_currency\": \"USD\", \"region\": 9, \"city\": \"Kyiv\", \"mileage\": 60000, \"engine_type\": \"gasoline\"}"
            },
            "description": "Profanity detected → status = needs_edit. Seller gets up to 3 edit attempts."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const data = pm.response.json();",
                  "pm.collectionVariables.set('profanity_listing_id', data.id);",
                  "pm.test('Status is needs_edit', () => pm.expect(data.status).to.equal('needs_edit'));",
                  "pm.test('Edit attempts = 0', () => pm.expect(data.edit_attempts).to.equal(0));"
                ]
              }
            }
          ]
        },
        {
          "name": "22. Edit listing — profanity again (attempt 1/3)",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/api/listings/{{profanity_listing_id}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{seller_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"description\": \"Toyota Camry блять продаю терміново\"}"
